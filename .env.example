# ==========================================
# APP
# ==========================================
APP_ENV=local
APP_NAME=Expedia-Hackathon-2026
APP_DEBUG=true
APP_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000

# ==========================================
# BACKEND / API
# ==========================================
API_V1_PREFIX=/api/v1
BACKEND_PORT=8000

# ==========================================
# DATABASE
# ==========================================
# Local dev default: SQLite file, no DB container required.
DATABASE_URL=sqlite+aiosqlite:///./data/app.db
DATABASE_URL_SYNC=sqlite:///./data/app.db

# --- To swap to PostgreSQL (self-hosted or managed) ---
# DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST:5432/DBNAME
# DATABASE_URL_SYNC=postgresql+psycopg2://USER:PASSWORD@HOST:5432/DBNAME

# --- To swap to Supabase (Supabase Postgres connection string) ---
# DATABASE_URL=postgresql+asyncpg://postgres:PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres
# DATABASE_URL_SYNC=postgresql+psycopg2://postgres:PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres
#
# After changing either of the above, just run: alembic upgrade head
# No other code changes are required — see docs/05-database-portability.md

# ==========================================
# REDIS
# ==========================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# ==========================================
# JWT / SECURITY
# ==========================================
# Generate with: openssl rand -hex 32
JWT_SECRET_KEY=CHANGE_ME_GENERATE_RANDOM_HEX_32
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
PASSWORD_HASH_SCHEME=argon2

# ==========================================
# CORS
# ==========================================
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ==========================================
# RATE LIMITING
# ==========================================
RATE_LIMIT_PER_MINUTE=60

# ==========================================
# OAUTH (fill in when needed)
# ==========================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
OAUTH_REDIRECT_URL=http://localhost:8000/api/v1/auth/oauth/callback

# ==========================================
# AI PROVIDERS (provider-agnostic layer)
# ==========================================
AI_PROVIDER=openai
OPENAI_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
AI_MODEL_NAME=gpt-4o-mini
AI_MAX_TOKENS=1024
AI_REQUEST_TIMEOUT_SECONDS=30

# ==========================================
# VECTOR DB (ready, unused until needed)
# ==========================================
VECTOR_DB_PROVIDER=pgvector
VECTOR_DB_URL=

# ==========================================
# FRONTEND (public, safe to expose)
# ==========================================
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_APP_NAME=Expedia Hackathon 2026
NEXT_PUBLIC_MAPS_PROVIDER=mapbox
NEXT_PUBLIC_MAPS_API_KEY=
